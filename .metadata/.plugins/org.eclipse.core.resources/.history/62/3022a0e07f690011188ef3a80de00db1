package com.careercompass_backend.model;

import java.time.LocalDateTime;

import jakarta.persistence.*;
import lombok.Data;
import lombok.NoArgsConstructor;

@Entity
@Table(name = "users")
@Data
@NoArgsConstructor
public class User {
	
	 /*
     * @Id marks this as the primary key.
     * @GeneratedValue(IDENTITY) tells MySQL to auto-increment this column.
     * We use Long (not int) because IDs can grow very large over time.
     */
	@Id
	@GeneratedValue(strategy = GenerationType.IDENTITY)
	private Long user_id;
	
	  /*
     * nullable = false → Hibernate adds NOT NULL constraint to the column.
     * This is enforced at the database level, not just in Java.
     */
	@Column(nullable = false)
	private String name;
	
	 /*
     * unique = true → Hibernate adds a UNIQUE constraint.
     * This is what prevents two users from registering with the same email.
     * The login system depends on email being a unique identifier.
     */
	@Column(unique = true , nullable = false)
	private String email;
	
	@Column(nullable = false)
	private String passwordHash;
	
	private String degree_type;
	private int passout_year;
	private String job_type;
	private String role;
	private boolean is_gap_candidate;
	private int gap_months;
	private String gap_reason;
	private LocalDateTime created_At;
	
	
	

}
